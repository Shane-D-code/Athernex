# Service Endpoints
WHISPER_ENDPOINT=http://localhost:8000
VOSK_ENDPOINT=http://localhost:8001
OLLAMA_ENDPOINT=http://localhost:11434
PIPER_ENDPOINT=http://localhost:8002

# Model Configuration
WHISPER_MODEL=medium
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# Confidence Thresholds
THRESHOLD_PLACE_ORDER=0.85
THRESHOLD_MODIFY_ORDER=0.80
THRESHOLD_CANCEL_ORDER=0.90
THRESHOLD_CONFIRM_ORDER=0.85
THRESHOLD_CHECK_STATUS=0.70
THRESHOLD_REQUEST_INFO=0.70

# Rate Limits (requests per minute)
RATE_LIMIT_WHISPER=10
RATE_LIMIT_OLLAMA=5
RATE_LIMIT_PIPER=50

# Resource Limits
MAX_CONCURRENT_REQUESTS=10
GPU_MEMORY_LIMIT_MB=7500
CPU_PERCENT_LIMIT=80

# Cache Configuration
LLM_CACHE_SIZE=1000
TTS_CACHE_SIZE=500
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Hugging Face (Fallback)
HF_API_KEY=your_hf_api_key_here
